{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./profile.schema.json",
  "title": "Composable Data Stack Profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "cds/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "Profile"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime", "modules"],
      "properties": {
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string"
            },
            "namespace": {
              "type": "string"
            }
          }
        },
        "modules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/moduleInstance"
          }
        },
        "secrets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "provider": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type"],
              "properties": {
                "type": {
                  "type": "string"
                }
              }
            },
            "values": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/secretValue"
              }
            }
          }
        },
        "outputs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "contracts": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/outputContract"
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "moduleInstance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "version", "enabled", "config"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "enabled": {
          "type": "boolean"
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "uniqueItems": true
        },
        "config": {
          "type": "object"
        }
      }
    },
    "secretValue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["env", "required"],
      "properties": {
        "env": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "outputContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from"],
      "properties": {
        "from": {
          "type": "string",
          "pattern": "^[a-z0-9-]+\\.[a-z0-9-]+$"
        }
      }
    }
  }
}
