{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track pip pins in Dagster entrypoint script",
      "fileMatch": [
        "^images/dagster/entrypoint\\.sh$"
      ],
      "matchStrings": [
        "(?<depName>dagster-postgres)==(?<currentValue>\\S+)",
        "(?<depName>dagster-mysql)==(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "pypi"
    },
    {
      "customType": "regex",
      "description": "Track Docker image tags in module definitions",
      "fileMatch": [
        "^modules/.+/module\\.yaml$"
      ],
      "matchStrings": [
        "image:\\s*(?<depName>[\\w./-]+):(?<currentValue>[\\w.-]+)"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Do not update local development image tags",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["local/dagster"],
      "enabled": false
    },
    {
      "groupName": "all dependencies",
      "matchPackagePatterns": [".*"]
    }
  ]
}